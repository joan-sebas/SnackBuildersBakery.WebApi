ASPNETCORE_ENVIRONMENT=Development
API_HTTP_PORT=8080

POSTGRES_DB=snack_builders
POSTGRES_USER=snack_builders
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

ConnectionStrings__SnackBuildersDb=Host=localhost;Port=5432;Database=snack_builders;Username=snack_builders;Password=change_me

# Two forms of the same keys, one per run mode:
#  - MANAGER_API_KEY / PUBLIC_API_KEY are read by docker-compose.yml and mapped into the container.
#  - Auth__ApiKeys__* are read directly by the app when running without compose (e.g. dotnet run).
MANAGER_API_KEY=manager-dev-key
PUBLIC_API_KEY=public-dev-key
Auth__ApiKeys__ManagerKey=manager-dev-key
Auth__ApiKeys__PublicKey=public-dev-key
